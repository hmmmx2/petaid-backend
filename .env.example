# Copy to .env and fill in. Never commit .env.
ENVIRONMENT=development

# --- Database -----------------------------------------------------------
# Local docker Postgres (default):
DATABASE_URL=postgresql+asyncpg://petaid:petaid@localhost:5432/petaid
#
# Supabase (see SUPABASE.md). Use the *Session pooler* or *Direct* string,
# rewritten to the asyncpg driver. Example (session pooler):
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# When the host is a Supabase host, SSL + statement-cache settings below are
# auto-applied, but you can also force them explicitly:
DB_SSL=false
DB_STATEMENT_CACHE_SIZE=0
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Auth ---------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- CORS ---------------------------------------------------------------
# Comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
